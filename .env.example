# ---- Runtime environment ----
# Path to the SQLite DB (source of truth). Defaults to ./data/app.db
DB_PATH=./data/app.db

# Directory where Plan screenshots / artifacts are written. Defaults to ./artifacts
ARTIFACTS_DIR=./artifacts

# ---- Sender identity (L3 templates / compliance §9) ----
# These are injected into the outbound message. Keep them truthful.
SENDER_COMPANY=ネオキャリア株式会社
SENDER_PRODUCT=MOCHICA
SENDER_PERSON=福井 翔
SENDER_EMAIL=sho.fukui@neo-career.co.jp
SENDER_PHONE=

# ---- L2 LLM fallback (optional). If absent, L2 falls back to rules only. ----
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

# ---- Pacing / safety (L4) ----
# Max final submissions per day (Execute phase). Plan/dry-run is unlimited.
DAILY_SEND_LIMIT=200
# Allowed sending window (24h local time). Outside this window Execute is blocked.
SEND_WINDOW_START=9
SEND_WINDOW_END=19
# Min / max random delay (ms) between final submissions.
SEND_MIN_INTERVAL_MS=45000
SEND_MAX_INTERVAL_MS=120000

# ---- Browser ----
# Set to "false" to watch the browser during debugging.
HEADLESS=true
